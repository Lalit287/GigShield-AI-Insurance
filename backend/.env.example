# GigShield Backend Environment Configuration

# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/gigshield
# For MongoDB Atlas:
# MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/gigshield

# JWT
JWT_SECRET=your_jwt_secret_key_change_in_production_min_32_chars_required
JWT_EXPIRE=7d

# External APIs
OPENWEATHER_API_KEY=your_openweather_api_key_here
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# Payment Gateway (Razorpay)
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Fraud Detection Thresholds
FRAUD_NO_ACTIVITY_HOURS=4
FRAUD_DUPLICATE_CLAIM_HOURS=24
FRAUD_SCORE_THRESHOLD=50

# Risk Calculation Weights
RISK_WEATHER_WEIGHT=0.4
RISK_AQI_WEIGHT=0.3
RISK_LOCATION_WEIGHT=0.3

# Trigger Thresholds
RAINFALL_THRESHOLD_MM=50
AQI_THRESHOLD=300
TEMP_THRESHOLD_C=42

# Email (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
